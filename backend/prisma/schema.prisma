generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ========== Enums ==========
enum LeadStatus {
    NEW
    QUALIFIED
    SITE_VISIT_SCHEDULED
    SITE_VISIT_DONE
    CONVERTED
    LOST
}

enum PropertyType {
    APARTMENT
    VILLA
    PLOT
    COMMERCIAL
}

enum ConversationState {
    ACTIVE
    COMPLETED
    HUMAN_HANDOFF
    OPTED_OUT
}

enum MessageRole {
    USER
    BOT
}

enum Purpose {
    INVESTMENT
    END_USE
}

enum Timeline {
    ONE_MONTH
    THREE_MONTHS
    SIX_MONTHS
    MORE_THAN_SIX_MONTHS
}

enum ProjectStatus {
    PRE_LAUNCH
    LAUNCHED
    UNDER_CONSTRUCTION
    READY_TO_MOVE
    COMPLETED
}

enum FollowUpStatus {
    PENDING
    SENT
    FAILED
}

enum OptInStatus {
    OPTED_IN
    OPTED_OUT
}

enum TemplateCategory {
    MARKETING
    UTILITY
    SERVICE
}

enum TemplateStatus {
    APPROVED
    PENDING
    REJECTED
}

// ========== Models ==========
model Builder {
    id                String   @id @default(cuid())
    businessName      String
    phoneNumberId     String   @unique
    encryptedToken    String
    wabaId            String
    verifyToken       String
    phoneNumber       String?
    notificationPhone String?
    systemPrompt      String?  @db.Text
    isActive          Boolean  @default(true)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    leads              Lead[]
    projects           Project[]
    optIns             OptIn[]
    whatsappTemplates  WhatsAppTemplate[]
    qualityRatings     QualityRating[]

    @@index([phoneNumber])
    @@index([isActive])
    @@map("builders")
}

model Lead {
    id                 String        @id @default(cuid())
    phone              String
    name               String?
    propertyType       PropertyType?
    location           String?
    bhk                String?
    purpose            Purpose?
    timeline           Timeline?
    amenities          String?       @db.Text
    possession         String?
    loanStatus         String?
    siteVisitDay       String?
    siteVisitTime      String?
    otherPropertyTypes String?
    minBudget          Int?
    maxBudget          Int?
    score              Int?          @default(0)
    status             LeadStatus    @default(NEW)
    createdAt          DateTime      @default(now())
    updatedAt          DateTime      @updatedAt

    builderId String
    builder   Builder @relation(fields: [builderId], references: [id])

    conversations Conversation[]
    followUps     FollowUp[]

    @@unique([phone, builderId])
    @@index([status])
    @@index([location])
    @@index([builderId])
    @@map("leads")
}

model Conversation {
    id                 String            @id @default(cuid())
    leadId             String
    langGraphThreadId  String            @unique
    languagePref       String            @default("en")
    state              ConversationState @default(ACTIVE)
    lastFollowUpSentAt DateTime?
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt

    lead     Lead      @relation(fields: [leadId], references: [id])
    messages Message[]

    @@map("conversations")
}

model Message {
    id                String      @id @default(cuid())
    whatsappMessageId String?     @unique
    conversationId    String
    role              MessageRole
    content           String      @db.Text
    createdAt         DateTime    @default(now())

    conversation Conversation @relation(fields: [conversationId], references: [id])

    @@map("messages")
}

model Locality {
    id          String  @id @default(cuid())
    name        String  @unique
    area        String?
    pincode     String?
    latitude    Float?
    longitude   Float?
    isNearITHub Boolean @default(false)
    rentRange   String?
    buyRange    String?
    commuteMap  Json?

    properties Property[]

    @@map("localities")
}

model Project {
    id          String        @id @default(cuid())
    builderId   String
    name        String
    description String?       @db.Text
    reraNumber  String?       @unique
    status      ProjectStatus @default(LAUNCHED)
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt

    builder    Builder     @relation(fields: [builderId], references: [id])
    properties Property[]
    reraDocs   ReraDoc[]

    @@map("projects")
}

model Property {
    id          String       @id @default(cuid())
    projectId   String
    localityId  String
    type        PropertyType
    bhk         String
    price       Int
    area        Int?
    status      String       @default("AVAILABLE")
    embedding   Unsupported("vector(1536)")?
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt

    project   Project  @relation(fields: [projectId], references: [id])
    locality  Locality @relation(fields: [localityId], references: [id])

    @@map("properties")
}

model FollowUp {
    id          String         @id @default(cuid())
    leadId      String
    scheduledAt DateTime
    type        String
    status      FollowUpStatus @default(PENDING)
    bullMQJobId String?
    createdAt   DateTime       @default(now())
    updatedAt   DateTime       @updatedAt

    lead Lead @relation(fields: [leadId], references: [id])

    @@index([scheduledAt, status])
    @@map("follow_ups")
}

model OptIn {
    id        String       @id @default(cuid())
    phone     String
    builderId String
    status    OptInStatus  @default(OPTED_IN)
    changedAt DateTime     @default(now())

    builder Builder @relation(fields: [builderId], references: [id])

    @@unique([phone, builderId])
    @@map("opt_ins")
}

model WhatsAppTemplate {
    id          String           @id @default(cuid())
    builderId   String
    name        String           @unique
    language    String           @default("en")
    category    TemplateCategory
    content     String           @db.Text
    metaStatus  TemplateStatus   @default(PENDING)
    createdAt   DateTime         @default(now())

    builder Builder @relation(fields: [builderId], references: [id])

    @@map("whatsapp_templates")
}

model QualityRating {
    id        String   @id @default(cuid())
    builderId String
    rating    Float
    date      DateTime @default(now())

    builder Builder @relation(fields: [builderId], references: [id])

    @@index([builderId, date])
    @@map("quality_ratings")
}

model ReraDoc {
    id          String   @id @default(cuid())
    projectId   String
    docType     String
    fileUrl     String
    uploadedAt  DateTime @default(now())

    project Project @relation(fields: [projectId], references: [id])

    @@map("rera_docs")
}